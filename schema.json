{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ailuminate-prompt-record",
  "title": "AILuminate Multilingual Prompt Record",
  "description": "Schema for a single record in the MSTS-APAC benchmark JSONL dataset.",
  "type": "object",
  "required": [
    "id",
    "prompt_en",
    "prompt_local",
    "culture",
    "language",
    "hazard_tag"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique record identifier (e.g. 'APAC-SG-001').",
      "pattern": "^[A-Z0-9][A-Z0-9_\\-]{2,63}$"
    },
    "image_url": {
      "type": ["string", "null"],
      "description": "Publicly accessible URL of the associated image, if any.",
      "format": "uri"
    },
    "image_sha256": {
      "type": ["string", "null"],
      "description": "SHA-256 hex digest of the image file for integrity verification.",
      "pattern": "^[a-f0-9]{64}$"
    },
    "prompt_en": {
      "type": "string",
      "description": "English canonical version of the prompt.",
      "minLength": 5,
      "maxLength": 1500
    },
    "prompt_local": {
      "type": "string",
      "description": "Prompt in the target language / locale.",
      "minLength": 5,
      "maxLength": 1500
    },
    "culture": {
      "type": "string",
      "description": "Primary cultural context (e.g. 'Singapore', 'Hindi-India', 'Ghana').",
      "minLength": 2
    },
    "language": {
      "type": "string",
      "description": "BCP-47 language code (e.g. 'en-SG', 'hi-IN', 'tw-GH').",
      "pattern": "^[a-z]{2,3}(-[A-Z]{2,3})?$"
    },
    "hazard_tag": {
      "type": "string",
      "description": "Primary hazard category from the cultural taxonomy.",
      "enum": [
        "hate",
        "self_harm",
        "political",
        "religious_sensitivity",
        "violence",
        "explicit",
        "historical_trauma",
        "social_norm_violation",
        "language_specific_taboo",
        "generic"
      ]
    },
    "cultural_relevance_score": {
      "type": ["number", "null"],
      "description": "Crowd-sourced relevance score (0.0 – 5.0 Likert average).",
      "minimum": 0.0,
      "maximum": 5.0
    },
    "annotation_version": {
      "type": ["string", "null"],
      "description": "Version tag of the annotation pass that produced this record (e.g. 'v0.5').",
      "pattern": "^v[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
    },
    "metadata": {
      "type": "object",
      "description": "Freeform key-value bag for extended provenance information.",
      "properties": {
        "source": {
          "type": "string",
          "description": "Origin of the prompt (e.g. 'MSTS-base', 'MSTS-MLC', 'partner-IMDA')."
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "reviewer_id": {
          "type": "string",
          "description": "Anonymised ID of the human reviewer who approved this record."
        },
        "expert_consensus": {
          "type": ["string", "null"],
          "enum": ["Safe", "Borderline", "Unsafe", null],
          "description": "Expert panel majority verdict, if available."
        }
      },
      "additionalProperties": true
    }
  }
}
