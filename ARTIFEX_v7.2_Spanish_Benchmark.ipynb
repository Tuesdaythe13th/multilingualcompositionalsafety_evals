   "outputs": [],
   "source": "#@title 12.1 EXECUTE: MATPLOTLIB_3D_SPANISH_ANALYTICS\nimport matplotlib\nimport matplotlib.pyplot as plt\nimport matplotlib.cm as mcm\nfrom mpl_toolkits.mplot3d import Axes3D\nfrom sklearn.decomposition import PCA\nfrom scipy.ndimage import gaussian_filter\nimport numpy as np\n\n_BG  = '#0a0a0a'; _G = '#1e1e1e'; _T = '#e8e8e8'; _A = '#e8ff00'\nmatplotlib.rcParams.update({\n    'figure.facecolor': _BG, 'axes.facecolor': _BG,\n    'text.color': _T, 'axes.labelcolor': _T,\n    'xtick.color': _T, 'ytick.color': _T, 'font.family': 'monospace',\n})\n\nprint(emoji.emojize(f':bar_chart: [{datetime.now().strftime(\"%H:%M:%S\")}] 3D Spanish Benchmark analytics...'))\n\ntry:\n    emb_arr = np.array(df['embedding'].tolist())\n    pca3 = PCA(n_components=3, random_state=42).fit(emb_arr)\n    c3   = pca3.transform(emb_arr)\n    ev   = pca3.explained_variance_ratio_\n\n    domain_list   = list(domain_results.index)\n    domain_vals   = domain_results.values\n    entropies_arr = results_df['entropy_bits'].values\n    verdicts_arr  = results_df['final_status'].values\n\n    fig = plt.figure(figsize=(22, 8), facecolor=_BG)\n    fig.suptitle('ARTIFEX v7.2 -- Spanish Benchmark 3D Analytics',\n                 fontsize=13, fontweight='bold', color=_A)\n\n    # Panel 1: 3D domain accuracy bars\n    ax1 = fig.add_subplot(1, 3, 1, projection='3d')\n    ax1.set_facecolor(_BG)\n    xpos = np.arange(len(domain_list), dtype=float)\n    norm_d = matplotlib.colors.Normalize(vmin=0, vmax=100)\n    cmap_d = mcm.get_cmap('RdYlGn')\n    dx = dy = 0.65\n    for i, (dom, acc) in enumerate(zip(domain_list, domain_vals)):\n        col = cmap_d(norm_d(acc))\n        ax1.bar3d(i - dx/2, 0, 0, dx, dy, acc,\n                  color=col, alpha=0.88, shade=True)\n        ax1.text(i, dy * 0.6, acc + 1.5, f'{acc:.0f}%',\n                 ha='center', fontsize=7, color=_T)\n    ax1.set_xticks(xpos)\n    ax1.set_xticklabels([d.replace(' ', '\\n') for d in domain_list], fontsize=6)\n    ax1.set_yticks([])\n    ax1.set_zlim(0, 110)\n    ax1.set_zlabel('Accuracy (%)', fontsize=8, labelpad=5)\n    ax1.set_title('3D Domain Accuracy Bars', color=_A, pad=8, fontsize=9)\n    ax1.tick_params(colors=_T, labelsize=6)\n    for p in [ax1.xaxis.pane, ax1.yaxis.pane, ax1.zaxis.pane]:\n        p.fill = False; p.set_edgecolor(_G)\n    ax1.grid(True, color=_G, linewidth=0.4)\n    ax1.view_init(elev=28, azim=-55)\n\n    # Panel 2: 3D PCA scatter coloured by final_status\n    ax2 = fig.add_subplot(1, 3, 2, projection='3d')\n    ax2.set_facecolor(_BG)\n    vcmap = {'AUTO_APPROVED': '#1a9641', 'AUTO_BLOCKED': '#d7191c',\n             'ROUTED_TO_HUMAN': '#fdae61'}\n    for verdict in set(verdicts_arr):\n        m = verdicts_arr == verdict\n        pts = c3[m]\n        ax2.scatter(pts[:, 0], pts[:, 1], pts[:, 2],\n                    color=vcmap.get(verdict, '#888'), s=18, alpha=0.75,\n                    label=verdict.replace('_', ' '), edgecolors='none',\n                    depthshade=True)\n    ax2.set_xlabel(f'PC1 ({ev[0]:.1%})', fontsize=7)\n    ax2.set_ylabel(f'PC2 ({ev[1]:.1%})', fontsize=7)\n    ax2.set_zlabel(f'PC3 ({ev[2]:.1%})', fontsize=7)\n    ax2.set_title('PCA 3D: Verdict Distribution', color=_A, pad=8, fontsize=9)\n    ax2.legend(markerscale=2, fontsize=7, facecolor='#1a1a1a',\n               edgecolor='#444', labelcolor=_T, loc='upper left')\n    ax2.tick_params(colors=_T, labelsize=6)\n    for p in [ax2.xaxis.pane, ax2.yaxis.pane, ax2.zaxis.pane]:\n        p.fill = False; p.set_edgecolor(_G)\n    ax2.grid(True, color=_G, linewidth=0.4)\n    ax2.view_init(elev=24, azim=-58)\n\n    # Panel 3: 3D entropy surface over PCA-1/2 plane\n    ax3 = fig.add_subplot(1, 3, 3, projection='3d')\n    ax3.set_facecolor(_BG)\n    H, xe, ye = np.histogram2d(c3[:, 0], c3[:, 1], bins=18,\n                                weights=entropies_arr)\n    Hc, _, _  = np.histogram2d(c3[:, 0], c3[:, 1], bins=18)\n    Hm = np.divide(H, Hc, out=np.zeros_like(H), where=Hc > 0).T\n    Hm = gaussian_filter(Hm, sigma=1.2)\n    Xm = 0.5 * (xe[:-1] + xe[1:]); Ym = 0.5 * (ye[:-1] + ye[1:])\n    Xg, Yg = np.meshgrid(Xm, Ym)\n    surf = ax3.plot_surface(Xg, Yg, Hm, cmap='magma', alpha=0.90,\n                             linewidth=0, antialiased=True, shade=True)\n    ax3.contourf(Xg, Yg, Hm, zdir='z', offset=Hm.min()-0.02,\n                 cmap='magma', alpha=0.28, levels=10)\n    ax3.set_xlabel('PC1', fontsize=7)\n    ax3.set_ylabel('PC2', fontsize=7)\n    ax3.set_zlabel('Mean Entropy (bits)', fontsize=7, labelpad=5)\n    ax3.set_title('3D Routing Entropy Landscape', color=_A, pad=8, fontsize=9)\n    ax3.tick_params(colors=_T, labelsize=6)\n    for p in [ax3.xaxis.pane, ax3.yaxis.pane, ax3.zaxis.pane]:\n        p.fill = False; p.set_edgecolor(_G)\n    ax3.grid(True, color=_G, linewidth=0.4)\n    ax3.view_init(elev=35, azim=-55)\n    fig.colorbar(surf, ax=ax3, shrink=0.45, pad=0.04,\n                 label='Mean Entropy').ax.yaxis.set_tick_params(color=_T)\n\n    plt.tight_layout()\n    plt.savefig('artifex_v72_3d_analytics.png', dpi=130,\n                bbox_inches='tight', facecolor=_BG)\n    plt.show()\n    print(emoji.emojize(':check_mark_button: 3D analytics saved to artifex_v72_3d_analytics.png'))\n\nexcept Exception as e:\n    print(f'3D visualization error: {e}')\n    import traceback; traceback.print_exc()\n"
